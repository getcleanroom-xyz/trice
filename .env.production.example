# --- Required ---

# PostgreSQL connection (Neon)
# Format: postgresql://user:password@host/db?sslmode=require
DATABASE_URL=

# Redis connection (Upstash)
# Format: redis://default:password@host:port
REDIS_URL=

# Public URL of the Next.js web app (magic link emails point here)
WEB_URL=https://trice.getcleanroom.xyz

# Public URL of the service app (the tip page fetches from the browser)
NEXT_PUBLIC_SERVICE_URL=

# Public URL the service uses for IPN/webhook callbacks
SERVICE_URL=

# Resend API key
RESEND_API_KEY=re_...

# Admin credentials
ADMIN_EMAIL=admin@getcleanroom.xyz
ADMIN_SESSION_SECRET=

# --- Optional (tip / payments) ---
FLUTTERWAVE_SECRET_KEY=
FLUTTERWAVE_WEBHOOK_SECRET=
NOWPAYMENTS_API_KEY=
NOWPAYMENTS_IPN_SECRET=
