# --- Required ---
DB_PASSWORD=                  # openssl rand -hex 16

# The public URL where the Next.js web app is served
WEB_URL=https://trice.getcleanroom.xyz

# The public URL where the service (Bun/Elysia) is served
# On Railway this will be something like https://trice-service.railway.app
# The tip page fetches from this URL directly in the browser.
NEXT_PUBLIC_SERVICE_URL=

# Internal URL the service uses for webhook callbacks (IPN)
# If you expose the service publicly at NEXT_PUBLIC_SERVICE_URL,
# use that same value here.
SERVICE_URL=

# Resend API key for sending emails
RESEND_API_KEY=re_...

# Admin login email and HMAC secret for the stateless admin session cookie
ADMIN_EMAIL=admin@getcleanroom.xyz
ADMIN_SESSION_SECRET=         # openssl rand -hex 32

# --- Optional (tip / payments) ---
FLUTTERWAVE_SECRET_KEY=
FLUTTERWAVE_WEBHOOK_SECRET=
NOWPAYMENTS_API_KEY=
NOWPAYMENTS_IPN_SECRET=
