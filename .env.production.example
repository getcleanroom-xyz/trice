# --- Required ---

# PostgreSQL connection (Neon serverless Postgres)
# Format: postgres://user:password@host/db?sslmode=require
DATABASE_URL=

# Redis connection (Upstash Redis)
# Format: redis://default:password@host:port
REDIS_URL=

# Public URL of the Next.js web app (used in magic link emails)
WEB_URL=https://trice.getcleanroom.xyz

# Public URL of the service app (used by the browser for payment links)
# On Railway this will be the generated *.railway.app domain for the service
NEXT_PUBLIC_SERVICE_URL=

# Internal URL the service uses for webhook callbacks (same as above on Railway)
SERVICE_URL=

# Resend API key for sending emails
RESEND_API_KEY=re_...

# Admin login email (must match what you enter on /admin/sign-in)
ADMIN_EMAIL=admin@getcleanroom.xyz

# HMAC secret for stateless admin session cookie (openssl rand -hex 32)
ADMIN_SESSION_SECRET=

# --- Optional (tip / payments) ---
FLUTTERWAVE_SECRET_KEY=
FLUTTERWAVE_WEBHOOK_SECRET=
NOWPAYMENTS_API_KEY=
NOWPAYMENTS_IPN_SECRET=
