# PostgreSQL connection string
DATABASE_URL=postgres://user:password@localhost:5432/trice

# Redis connection string (for BullMQ)
REDIS_URL=redis://localhost:6379

# Port the service listens on
PORT=4000

# Public URL of the web app (for CORS and magic link generation)
WEB_URL=http://localhost:3000

# Public URL of the service itself (for IPN webhook callbacks)
SERVICE_URL=http://localhost:4000

# Resend API key for email delivery
RESEND_API_KEY=

# --- Optional (tip / payments) ---
FLUTTERWAVE_SECRET_KEY=
FLUTTERWAVE_WEBHOOK_SECRET=
NOWPAYMENTS_API_KEY=
NOWPAYMENTS_IPN_SECRET=
