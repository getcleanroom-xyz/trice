# PostgreSQL connection string
DATABASE_URL=postgres://user:password@localhost:5432/trice

# Public URL of the service app (used by the browser for payment links)
NEXT_PUBLIC_SERVICE_URL=http://localhost:4000

# Public URL of the web app (used in email links)
WEB_URL=http://localhost:3000

# Resend API key for admin login emails
RESEND_API_KEY=

# Admin credentials
ADMIN_EMAIL=you@example.com
# Generate with: openssl rand -hex 32
ADMIN_SESSION_SECRET=
